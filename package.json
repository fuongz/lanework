{
  "name": "lanework",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Visualize a GitHub repo's .agents/reviews folder as a Kanban board. TanStack Start + Cloudflare Workers + Better Auth.",
  "license": "MIT",
  "author": "fuongz <phuong.phung@hiip.asia>",
  "homepage": "https://github.com/fuongz/lanework#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/fuongz/lanework.git"
  },
  "bugs": {
    "url": "https://github.com/fuongz/lanework/issues"
  },
  "keywords": [
    "kanban",
    "tanstack-start",
    "cloudflare-workers",
    "better-auth",
    "github",
    "ai-agents",
    "code-review",
    "drizzle",
    "d1"
  ],
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply prod-lanework --local",
    "db:migrate:remote": "wrangler d1 migrations apply prod-lanework --remote",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.2.1",
    "@hugeicons/react": "^1.1.7",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "better-auth": "^1.6.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "motion": "^12.40.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "recharts": "3.8.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.103.0"
  }
}
